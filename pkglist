# === [ CORE & SHELL ] ===
zsh                         # zsh shell
zsh-autosuggestions         # was der name sagt. auto suggestion beim tippen. keine autosuggestion lol
zsh-syntax-highlighting     # syntax highlighting in zsh
stow                        # managed symlinks für die dotfiles
zoxide                      # schnelles vrrzeichnis-springen (j)
eza                         # moderner ls-ersatz in rust
bat                         # moderner cat-ersatz mit syntax-highlighting
ripgrep                     # extrem schnelle textsuche (rg). kann fast alles von grep nur manchmal halt irgendwie anders
fzf                         # suchmaske für dateien und befehle
fd                          # schnellerer ersatz für find
fastfetch                   # systeminfos. obligatorischer ricing flex
btop                        # schön gebügelter system monitor

# === [ EDITORS & FILE MANAGEMENT ] ===
helix                       # helix ist ein tui editor. macht mehr spaß als nvim
yazi                        # yazi ist ein terminal dateibrowser. wird über configfiles gesteuert und ist schnell und angehm
lazygit                     # tui für git, bisschen überflüssig aber frisst kaum platz
yt-dlp                      # video downloader im terminal. falls mpv nicht reicht
tldr                        # manpages read many word, bad. tldr read few word, good
wl-clipboard                # copy und paste unter wayland.
rsync                       # datei syncing
poppler                     # PDF-vorschau. zb in yazi
p7zip                       # supported 7zip archive
unrar                       # das gleiche für rar
glow                        # Markdown. funktioniert so semi geil, aber fürs erste bleibt der drin
zed                         # zed text editor /IDE. tolles ding

# === [ MEDIA & GUI APPS ] ===
firefox                     # browser. wird mal bei gelegenheit durch librewolf ersetzt
mpv                         # video player. einfach und gut. kann komischerweise mehr als vlc zb gutes av1 decoding und hdr selbst von gestreamten videos
imv                         # bildbetrachter
zathura                     # PDF-viewer (typst-kompatibel)
zathura-pdf-mupdf           # PDF-engine für zathura

# === [ HYPRLAND INFRA & TOOLS ] ===
waybar                      # statusleiste
wofi                        # app launcher und praktisch als skript starter
mako                        # einfacher benachrichtigungsdienst
hyprlock                    # sperrbildschirm
hyprpaper                   # hintergrundbild manager. so sehr ich hyprland mag sind doch die standards cringe
xdg-desktop-portal-hyprland # screensharing und datei dialoge
pavucontrol                 # gui programm für sound steuerung
pulsemixer                  # sound mixer fürs terminal
